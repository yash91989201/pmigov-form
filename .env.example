# API server
PORT=4000

# Password for the /admin panel (change before deploying)
ADMIN_PASSWORD=pmigov-admin

# Comma-separated browser origins allowed to call the API (split client/API deploy).
# Example: https://consent.pmigov.com
# CORS_ORIGINS=

# Postgres owner connection — used only for migrations (DDL + role/grant setup)
DATABASE_URL=postgres://pmigov:pmigov@localhost:5432/pmigov

# Least-privilege role the app runs as (SELECT/INSERT/DELETE, no UPDATE).
# Auto-created by the migration; the app then connects as this role.
APP_DB_USER=pmigov_app
APP_DB_PASSWORD=pmigov-app-secret

# MinIO / S3-compatible storage (matches the docker-compose `minio` service,
# published on host port 9002)
S3_ENDPOINT=localhost
S3_PORT=9002
S3_USE_SSL=false
S3_ACCESS_KEY=pmigov
S3_SECRET_KEY=pmigov-secret
S3_BUCKET=pmigov-forms

# Browser-reachable MinIO endpoint used to sign presigned image URLs. Leave
# unset for local dev (server and browser share localhost:9002). In Docker the
# server uses the internal host, so set this to the published/public endpoint.
# S3_PUBLIC_ENDPOINT=http://localhost:9002

# How long presigned image URLs stay valid, in seconds (default 600).
# PRESIGN_EXPIRY=600

# Redis for caching presigned URLs (optional — omit to run without a cache).
REDIS_URL=redis://localhost:6379

# Client build (Dockerfile.client / Vite) — full API base including /api
# VITE_API_URL=https://api.consent.pmigov.com/api